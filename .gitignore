# This file is a "do NOT pack" list for git.
# Anything written here stays on YOUR computer and never goes to GitHub —
# because it's junk the computer can remake anytime.
#
# IMPORTANT: each comment must be on its OWN line. Git only treats a line
# as a comment if it STARTS with "#" — a "#" note stuck on the end of a
# pattern line becomes part of the pattern itself instead of being ignored,
# which quietly breaks that rule. (That bug lived here before v1.5.0 — every
# rule below except the last few had this problem and wasn't actually
# working. Fixed now, and keep new rules one-line-pattern/one-line-comment.)

# Python's scratch paper (it redraws this whenever it wants)
__pycache__/
*.pyc

# PyInstaller's messy workbench while building the app
build/
# The finished app files (too big for git — we share these
# through GitHub Releases instead)
dist/
# PyInstaller's recipe notes (it rewrites these each build)
*.spec

# A private toy box of Python packages (everyone makes their own)
.venv/
venv/

# Icon files the build scripts generate automatically from skz-logo.png —
# no need to store them, they get remade on every build.
skz-logo.ico
skz-logo.icns
skz.iconset/

# Settings file the app writes while running (belongs on each user's machine)
skz_countdown_settings.json

# pytest's own scratch folder from running the tests
.pytest_cache/

# Scratch notes from testing/running the app by hand (not part of the app)
*.log
